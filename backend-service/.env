# ============================================
# PostgreSQL Connection
# DB_NAME = PostgreSQL database name on CloudClusters (NOT a schema)
# Schemas inside this DB:
#   - otaxdb     → Core app tables (auth, RBAC, organizations, ETA)
#   - InvoicesDb → Dynamic per-org invoice tables
#   - LoginDb    → Legacy (not used)
#   - public     → Legacy (not used)
# ============================================
DB_HOST=postgresql-17417-0.cloudclusters.net
DB_PORT=17417
DB_NAME=LoginDb
DB_USER=admin
DB_PASS=admin123$456
PORT=3001

# Prisma Database URL (connects to LoginDb database, uses otaxdb schema)
DATABASE_URL="postgresql://admin:admin123$456@postgresql-17417-0.cloudclusters.net:17417/LoginDb?schema=otaxdb"

# JWT Secret for Authentication
JWT_SECRET=OTax-E-Invoice-Super-Secret-Key-2026-Change-In-Production

# Symmetric key for at-rest encryption of secrets in org_integration_settings
# (ERP password, log DB password). 48 random bytes, base64-encoded — derived
# down to 32 bytes via SHA-256 by services/secrets.ts. Rotating this key makes
# previously-encrypted ciphertexts unrecoverable, so DO NOT change it once
# secrets are stored without first re-encrypting them.
SECRETS_ENCRYPTION_KEY=3o+4fWL34wJx3M+GDicK0mOl9v/BMCWQ0Y++noRvjisg3p/hCy3MFeKTfbPW6IID

# SMTP (Gmail) for OTP Emails
SMTP_USER=otax.tech@gmail.com
SMTP_PASS=qecsmxrupkaheurj
SMTP_FROM=OTax Platform <otax.tech@gmail.com>